# Use the official Jenkins LTS image as base
FROM jenkins/jenkins:latest

# Switch to root to install extra packages (optional)

USER root
COPY ./cert/MITRE_BA_ROOT.crt /usr/local/share/ca-certificates/corp-root-ca.crt

RUN apt-get update && apt-get install -y ca-certificates openssl \
 && update-ca-certificates \
 && keytool -importcert -noprompt -trustcacerts \
      -alias corp-root-ca \
      -file /usr/local/share/ca-certificates/corp-root-ca.crt \
      -keystore "$JAVA_HOME/lib/security/cacerts" \
      -storepass changeit


# Create a volume for Jenkins home (persistent config and jobs)
VOLUME /var/jenkins_home

# Expose Jenkins web UI and agent ports
EXPOSE 8080 50000

# Drop back to the jenkins user for runtime
USER jenkins

# Jenkins entrypoint is already defined in the base image
# So we just inherit it; no CMD or ENTRYPOINT needed.
